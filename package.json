{
  "name": "shm-platform",
  "version": "1.0.0",
  "private": true,
  "description": "SHM — backend (Node/Express/SQLite) + 3 frontends estáticos servidos desde el mismo backend",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "cd backend && node server.js",
    "dev": "cd backend && npm run dev",
    "install:backend": "cd backend && npm ci --omit=dev",
    "init-db": "cd backend && npm run init-db"
  }
}
