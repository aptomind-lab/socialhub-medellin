# ────────────────────────────────────────────────────────────────
# SHM — variables del backend
# Copia este archivo a .env (local) o configúralas en Railway (prod).
# NUNCA subas .env al repositorio.
# ────────────────────────────────────────────────────────────────

# Puerto del servidor. Railway lo asigna automáticamente — no lo fuerces en prod.
PORT=4000

# Modo de ejecución. En Railway pon: production
NODE_ENV=development

# ─── Persistencia (SQLite) ──────────────────────────────────────
# Local: ruta relativa funciona.
# Railway: monta un volumen persistente y apunta DB_PATH a él.
#          Ejemplo: DB_PATH=/data/socialhub.db
DB_PATH=./db/socialhub.db

# ─── Seguridad ──────────────────────────────────────────────────
# Cambia este secreto en producción (genera con: openssl rand -hex 32).
JWT_SECRET=cambia-este-secreto-en-produccion

# Contraseña por defecto del seed inicial (líderes fundadores).
# Cámbiala apenas hagas el primer login.
DEFAULT_USER_PASSWORD=Sh2026!

# ─── URLs públicas ──────────────────────────────────────────────
# URL pública del backend. Se usa para QRs e enlaces de email (reset, welcome).
# Railway: https://tu-backend.up.railway.app
PUBLIC_BASE_URL=http://localhost:4000

# Orígenes permitidos por CORS. Separa múltiples con coma. * = cualquiera.
# Prod: FRONTEND_URL=https://tu-app.com,https://landing.tu-dominio.com
FRONTEND_URL=*

# ─── Email SMTP (welcome, reset password, QR del invitado) ──────
# Gmail con App Password: requiere 2FA activado y generar contraseña de aplicación.
# Brevo / Resend / Mailgun también funcionan — basta con cambiar host/port/user/pass.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-app-password
SMTP_FROM="SHM <no-reply@tu-dominio.com>"

# ─── Reglas de negocio ──────────────────────────────────────────
# Horas sin registrar mensajes antes de bloquear el código del distribuidor.
INACTIVITY_BLOCK_HOURS=48
